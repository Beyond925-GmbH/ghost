# Fallback image: apply Resend server patches onto official Ghost 6.
# Use when the full monorepo GHCR build is unavailable.
FROM ghost:6-alpine

USER root

COPY patches/core/server/services/email-service/bulk-email-provider-factory.js \
  /var/lib/ghost/current/core/server/services/email-service/bulk-email-provider-factory.js
COPY patches/core/server/services/email-service/resend-email-provider.js \
  /var/lib/ghost/current/core/server/services/email-service/resend-email-provider.js
COPY patches/core/server/services/lib/resend-client.js \
  /var/lib/ghost/current/core/server/services/lib/resend-client.js
COPY patches/core/server/services/email-analytics/email-analytics-provider-resend.js \
  /var/lib/ghost/current/core/server/services/email-analytics/email-analytics-provider-resend.js
COPY patches/email-service-wrapper.js \
  /var/lib/ghost/current/core/server/services/email-service/email-service-wrapper.js
COPY patches/email-analytics-service-wrapper.js \
  /var/lib/ghost/current/core/server/services/email-analytics/email-analytics-service-wrapper.js
COPY patches/email-suppression-list-service.js \
  /var/lib/ghost/current/core/server/services/email-suppression-list/service.js

RUN chown -R node:node /var/lib/ghost/current/core/server

USER node
WORKDIR /var/lib/ghost/current
RUN yarn add resend@4 --ignore-workspace-root-check
