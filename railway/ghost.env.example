# Railway Ghost service variables.
# Do not set bridge variables like HUBSPOT_ACCESS_TOKEN here.
NODE_ENV=production
url=https://newsletter.beyond925.de

# MySQL (use Railway reference syntax)
database__client=mysql
database__connection__host=${{MySQL.MYSQLHOST}}
database__connection__port=${{MySQL.MYSQLPORT}}
database__connection__user=${{MySQL.MYSQLUSER}}
database__connection__password=${{MySQL.MYSQLPASSWORD}}
database__connection__database=${{MySQL.MYSQLDATABASE}}

# Bulk newsletters via Resend
bulkEmail__provider=resend
bulkEmail__resend__apiKey=${{RESEND_API_KEY}}

# Transactional mail (login codes, invites)
mail__transport=SMTP
mail__options__host=smtp.resend.com
mail__options__port=465
mail__options__secure=true
mail__options__auth__user=resend
mail__options__auth__pass=${{RESEND_API_KEY}}
mail__from=Team beyond925 <newsletter@beyond925.de>

# Secret to add in Railway (not committed):
# RESEND_API_KEY=re_...
